{
  "name": "qcs-system-test",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "printStaLogo": "node ./QCSUtils/reportUtils/logoPrinter.js",
    "start": "bash start.sh",
    "wdiolocal": "bash ./scripts/wdio_local.sh",
    "apitest": "node ./config/apitestconfig.js",
    "toolstest": "node ./config/toolsconfig.js",
    "apitestparallel": "node ./config/apitestconfig.js --parallel",
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "jsdoc": "jsdoc -c ./jsdoc.conf.json",
    "writeff-file": "node -e \"import('./QCSUtils/testUtils/featureFlagConfiguration.js').then(module => module.default.saveFlagsToFile())\"",
    "classify": "node -e \"import('./QCSUtils/reportUtils/classifier/classifier.js').then(module => module.Classifier.run())\"",
    "publishToPG": "node ./QCSUtils/testUtils/pgdataHandler.js",
    "publishToMySQL": "node ./QCSUtils/testUtils/mysqldataHandler.js",
    "qmfeSuites": "node -e \"import('./QCSUtils/reportUtils/qmfeSuites.js').then(module => module.default.generateSuitesFile('./reports/guiTestData.json', './reports/qmfeSuites.json'))\"",
    "flagsCompare": ". ./scripts/env_vars.sh && node ./QCSUtils/testUtils/flagesComparison.js",
    "suiteSummary": "node ./QCSUtils/SuitesUtils/generateSuitesSummary.js",
    "checkDescriptions": "node QCSUtils/SuitesUtils/checkDescriptions.js",
    "precommitSuitesSummary": "node QCSUtils/SuitesUtils/precommitSuitesSummary.js"
  },
  "pre-commit": [
    "lint",
    "checkDescriptions",
    "precommitSuitesSummary"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qlik-trial/qcs-system-test.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/qlik-trial/qcs-system-test/issues"
  },
  "homepage": "https://github.com/qlik-trial/qcs-system-test#readme",
  "dependencies": {
    "@aws-sdk/client-rds": "^3.946.0",
    "@babel/parser": "^7.28.5",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^1.19.0",
    "@opentelemetry/resources": "^1.19.0",
    "@opentelemetry/sdk-trace-base": "^1.19.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@qlik-trial/gtp-coverage-reporter": "1.0.32",
    "@qlik-trial/sta-report": "1.0.61",
    "@reportportal/agent-js-webdriverio": "latest",
    "@reportportal/client-javascript": "latest",
    "@wdio/cli": "9.22.0",
    "@wdio/devtools-service": "8.40.2",
    "@wdio/globals": "9.17.0",
    "@wdio/jasmine-framework": "9.5.7",
    "@wdio/local-runner": "9.22.0",
    "@wdio/spec-reporter": "9.20.0",
    "@wdio/visual-service": "6.3.1",
    "adm-zip": "^0.5.16",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "asciiart-logo": "0.2.7",
    "axios": "^1.8.2",
    "axios-retry": "^4.5.0",
    "cheerio": "^1.1.2",
    "docdash": "^2.0.1",
    "enigma.js": "^2.14.0",
    "escape-html": "^1.0.3",
    "expect-webdriverio": "^5.0.5",
    "fs-extra": "11.3.2",
    "glob": "^11.0.2",
